# ⚙️ Eagle Watcher — 设备配置模板
# 复制为 ~/.eagle-watcher/config.yaml 后按需修改

eagle:
  host: "http://localhost:41595"
  token: ""  # ← 必填：Eagle → 偏好设置 → 插件 → API Token

paths:
  downloads: "~/Downloads"          # 主监控路径（支持 ~ 展开）
  extra_watch_dirs: []              # 额外监控目录列表（可选）
  # extra_watch_dirs:              # 示例：
  #   - "~/Desktop/素材暂存"
  #   - "/Users/Shared/Designs"
  watch_interval: 2.0               # 监控轮询间隔（秒）

notifications:
  inbox_reminder: true              # 有待分类素材时通知
  import_success: false             # 导入成功时通知

ai:
  api_key: ""                       # ← DashScope API Key（Qwen-VL 视觉分析用）
  model: "qwen-vl-max"              # 模型名称
